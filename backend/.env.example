# ═══════════════════════════════════════════════════
# QuadraJá — Variáveis de Ambiente
# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env no git
# ═══════════════════════════════════════════════════

# ── Banco de Dados ───────────────────────────────────
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# ── Servidor ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────
# Gere uma chave forte com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="950c23fe56f9d1c5bc040c2d478cb02f9779df1361809b666a208b570822b171b09e9a203ff2cde2f7bcc0ce56c83ededbdea83121d7e486ed2813e31a4c4e2a"

# ── Frontend (para CORS) ──────────────────────────────
# Em dev: http://localhost:5500
# Em produção: http://SEU_IP_FIXO ou https://seudominio.com
FRONTEND_URL="http://localhost:5500"

# ── URL pública da API (para webhooks do Mercado Pago) ─
# Em dev: use ngrok (npx ngrok http 3001)
# Em produção: http://SEU_IP_FIXO
APP_URL="http://localhost:3001"

# ── Mercado Pago — SANDBOX (testes) ──────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN_TEST="TEST-0000000000000000-000000-00000000000000000000000000000000-000000000"
MP_PUBLIC_KEY_TEST="TEST-00000000-0000-0000-0000-000000000000"
MP_WEBHOOK_SECRET="seu-webhook-secret-do-painel-mp"

# ── Mercado Pago — PRODUÇÃO (descomente quando pronto) ─
# MP_ACCESS_TOKEN="APP_USR-xxxx"
# MP_PUBLIC_KEY="APP_USR-xxxx"

# ── E-mail via Resend (opcional por enquanto) ─────────
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# EMAIL_FROM="noreply@quadraja.com.br"

# ── SMS via Twilio (opcional por enquanto) ────────────
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_PHONE_NUMBER="+5511999999999"
